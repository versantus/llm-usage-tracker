# Copy to .env.local for local development overrides.

# Where the client POSTs usage events (defaults to http://localhost:4317)
LUT_SERVER_URL=http://localhost:4317

# Override the identity email used by the client (defaults to config.json)
# LUT_USER_EMAIL=you@example.com

# Server overrides
# LUT_PORT=4317
# LUT_DB_PATH=/custom/path/server.db

# --- Access control (fail-closed) ---
# The server DENIES all access (503) unless auth is configured. For local dev,
# run without auth by setting this explicitly:
LUT_ALLOW_NO_AUTH=1
# In production, leave LUT_ALLOW_NO_AUTH unset and set these instead:
# LUT_DASH_USER=admin            # dashboard + API Basic Auth username (optional)
# LUT_DASH_PASS=change-me        # dashboard + API Basic Auth password (required to unlock)
# LUT_INGEST_TOKEN=some-secret   # shared token clients send on /ingest
